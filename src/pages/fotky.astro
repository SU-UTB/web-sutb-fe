const metaTags = {
  title: 'Galerie | Studentská unie UTB',
  description: 'Prohlédněte si fotogalerie z našich uplynulých projektů a akcí.',
  image: '/meta-image-galerie.jpg',
};
---

<Layout {...metaTags}>
  <section class="pt-8 sm:pt-10 lg:pt-12 pb-16 bg-gradient-to-b from-white via-stone-100 to-stone-100 min-h-screen">
    <Container>
      <Breadcrumbs
        items={[
          {
            title: 'Galerie',
            href: '/galerie',
          },
        ]}
      />
      <H1>Galerie</H1>
      <p class="sm:text-lg lg:text-xl pt-6 pb-10 text-stone-700 tracking-wide leading-relaxed sm:leading-relaxed lg:leading-relaxed max-w-3xl">
        Zavzpomínej s námi na uplynulé ročníky našich projektů. Vyber si rok, klikni na složku projektu a prohlédni si všechna alba plná vzpomínek.
      </p>

      <!-- Výpis let (Dropdowny) -->
      <div class="space-y-6">
        {galleryData.map((yearGroup, index) => (
          <details class="group bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden" open={index === 0}>
            <summary class="flex justify-between items-center cursor-pointer p-6 sm:p-8 font-semibold text-2xl text-stone-800 hover:bg-stone-50 transition-colors list-none">
              <span>Rok {yearGroup.year}</span>
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                class="h-6 w-6 text-stone-400 group-open:-rotate-180 transition-transform duration-300" 
                fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            
            <div class="p-6 sm:p-8 pt-0 bg-white">
              <!-- Grid složek / samostatných alb projektů -->
              <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 sm:gap-8">
                {yearGroup.projects.map((project) => {
                  const isSingleAlbum = project.albums.length === 1;

                  // SINGLE ALBUM
                  if (isSingleAlbum) {
                    const album = project.albums[0];
                    return (
                      <a 
                        href={album.link} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="flex flex-col items-center group/album text-left w-full focus:outline-none"
                        aria-label={`Otevřít album ${project.name}`}
                      >
                        <div class="w-full relative transition-transform duration-300 group-hover/album:-translate-y-2 group-hover/album:drop-shadow-lg">
                          <!-- Spacer zajišťující vizuální zarovnání s hlavičkami (oušky) složek -->
                          <div class="w-full h-4"></div>
                          <!-- Tělo - Single karta -->
                          <div class="w-full aspect-square bg-stone-100 rounded-2xl p-2 shadow-md overflow-hidden relative border border-stone-200/60">
                            <div class="w-full h-full rounded-lg overflow-hidden relative">
                              <img 
                                src={getImage(album.image)?.src || getImage(album.image)} 
                                alt={album.title} 
                                class="w-full h-full object-cover group-hover/album:scale-105 transition-all duration-500"
                                loading="lazy"
                              />
                              <div class="absolute inset-0 bg-gradient-to-tr from-black/5 to-transparent pointer-events-none"></div>
                              <!-- Ikonka odskoku -->
                              <div class="absolute top-3 right-3 bg-white/90 backdrop-blur text-stone-800 p-1.5 rounded-full opacity-0 group-hover/album:opacity-100 transition-opacity shadow-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                              </div>
                            </div>
                          </div>
                        </div>
                        <span class="mt-3 font-semibold text-stone-800 text-center w-full truncate px-1 group-hover/album:text-orange-600 transition-colors">
                          {project.name}
                        </span>
                        <span class="text-sm text-stone-500">{project.albums.length}&nbsp;{getAlbumWord(project.albums.length)}</span>
                      </a>
                    );
                  }

                  // FOLDER MULTIPLE ALBUMS - Vždy 4 okénka (2x2)
                  return (
                    <button 
                      class="folder-btn flex flex-col items-center group/folder text-left w-full focus:outline-none"
                      data-modal-target={`modal-${project.id}`}
                      aria-label={`Otevřít galerii projektu ${project.name}`}
                    >
                      <!-- Tvar složky -->
                      <div class="w-full relative transition-transform duration-300 group-hover/folder:-translate-y-2 group-hover/folder:drop-shadow-lg">
                        <!-- Ouško složky -->
                        <div class="w-1/3 h-4 bg-orange-400 rounded-t-lg ml-3 shadow-inner"></div>
                        <!-- Tělo složky s pevným 2x2 gridem -->
                        <div class="w-full aspect-square bg-orange-300 rounded-2xl rounded-tl-none p-2 grid grid-cols-2 grid-rows-2 gap-2 shadow-md overflow-hidden relative border-t border-white/20">
                          
                          {/* Zobrazíme až 4 obrázky jako náhledy */}
                          {project.albums.slice(0, 4).map((album) => (
                            <div class="w-full h-full bg-orange-200 rounded-lg overflow-hidden">
                              <img 
                                src={getImage(album.image)?.src || getImage(album.image)} 
                                alt={`Náhled ${album.title}`} 
                                class="w-full h-full object-cover transition-opacity"
                                loading="lazy"
                              />
                            </div>
                          ))}
                          
                          {/* Doplnění prázdných míst do počtu 4, pokud je alb méně */}
                          {Array.from({ length: Math.max(0, 4 - project.albums.length) }).map(() => (
                            <div class="w-full h-full bg-orange-200/50 rounded-lg"></div>
                          ))}
                          
                          <!-- Odlesk složky pro 3D efekt -->
                          <div class="absolute inset-0 bg-gradient-to-tr from-black/5 to-white/20 pointer-events-none"></div>
                        </div>
                      </div>
                      <span class="mt-3 font-semibold text-stone-800 text-center w-full truncate px-1 group-hover/folder:text-orange-600 transition-colors">
                        {project.name}
                      </span>
                      <span class="text-sm text-stone-500">{project.albums.length}&nbsp;{getAlbumWord(project.albums.length)}</span>
                    </button>
                  );
                })}
              </div>
            </div>
          </details>
        ))}
      </div>
    </Container>
  </section>

  <!-- Vygenerování všech pop-up oken na konci dokumentu (pouze pro projekty s >1 albem) -->
  {galleryData.map((yearGroup) => 
    yearGroup.projects
      .filter((project) => project.albums.length > 1) 
      .map((project) => (
        <div 
          id={`modal-${project.id}`} 
          class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6 opacity-0 pointer-events-none transition-opacity duration-300 ease-out"
          role="dialog"
          aria-modal="true"
        >
          <!-- Tmavé pozadí (Backdrop) -->
          <div class="absolute inset-0 bg-stone-900/60 backdrop-blur-sm modal-backdrop transition-opacity"></div>
          
          <!-- Samotné okno -->
          <!-- Přidána kontrola max-height a overflow, aby se okno správně zobrazilo vždy uprostřed a šlo scrollovat -->
          <div class="relative bg-white rounded-3xl w-full max-w-5xl max-h-[90vh] flex flex-col shadow-2xl transform scale-95 transition-transform duration-300 ease-out modal-content">
            
            <!-- Hlavička modálu (Zůstává pevně nahoře) -->
            <div class="flex justify-between items-center p-6 sm:px-8 border-b border-stone-100 shrink-0">
              <div>
                <p class="text-sm font-semibold tracking-wider text-orange-500 uppercase mb-1">Rok {yearGroup.year}</p>
                <h2 class="text-2xl sm:text-3xl font-bold text-stone-800">{project.name}</h2>
              </div>
              <button class="modal-close p-2 text-stone-400 hover:text-stone-800 hover:bg-stone-100 rounded-full transition-colors focus:outline-none" aria-label="Zavřít galerii">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            
            <!-- Obsah - Grid alb (Scrollovatelná část) -->
            <div class="p-6 sm:p-8 overflow-y-auto custom-scrollbar">
              <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                {project.albums.map((album) => (
                  <a 
                    href={album.link} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="group/modal flex flex-col bg-stone-50 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 border border-stone-100 hover:-translate-y-1 focus:outline-none focus:ring-4 focus:ring-orange-300"
                  >
                    <div class="aspect-[4/3] w-full overflow-hidden relative">
                      <img 
                        src={getImage(album.image)?.src || getImage(album.image)} 
                        alt={album.title} 
                        class="w-full h-full object-cover group-hover/modal:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                      <!-- Ikonka odskoku -->
                      <div class="absolute top-3 right-3 bg-white/90 backdrop-blur text-stone-800 p-1.5 rounded-full opacity-0 group-hover/modal:opacity-100 transition-opacity shadow-sm">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </div>
                    </div>
                    <div class="p-4 bg-white flex-1 flex items-center justify-center">
                      <h3 class="font-bold text-stone-800 text-center line-clamp-2">{album.title}</h3>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))
  )}
</Layout>

<script>
  // Astro podpora pro View Transitions (pokud je používáš)
  document.addEventListener('astro:page-load', initModals);
  // Základní event pro případ, že View Transitions vypnuté
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initModals);
  } else {
    initModals();
  }

  function initModals() {
    const folderButtons = document.querySelectorAll('.folder-btn');
    const closeButtons = document.querySelectorAll('.modal-close');
    const backdrops = document.querySelectorAll('.modal-backdrop');
    
    let activeModal: HTMLElement | null = null;

    // Funkce pro otevření okna
    function openModal(modalId: string) {
      const modal = document.getElementById(modalId);
      if (!modal) return;
      
      // Zobrazení a uzamčení scrollování stránky
      // Přidáme .flex místo .hidden, aby začalo fungovat centrování (items-center justify-center)
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      
      document.body.style.overflow = 'hidden';
      activeModal = modal;
      
      // Malé zpoždění pro plynulý průběh CSS transition
      requestAnimationFrame(() => {
        modal.classList.remove('opacity-0', 'pointer-events-none');
        const content = modal.querySelector('.modal-content');
        if (content) {
          content.classList.remove('scale-95');
          content.classList.add('scale-100');
        }
      });
    }

    // Funkce pro zavření okna
    function closeModal() {
      if (!activeModal) return;
      
      activeModal.classList.add('opacity-0', 'pointer-events-none');
      const content = activeModal.querySelector('.modal-content');
      if (content) {
        content.classList.remove('scale-100');
        content.classList.add('scale-95');
      }
      
      // Po skončení animace skryjeme úplně (přepneme zpět flex -> hidden)
      setTimeout(() => {
        if(activeModal) {
          activeModal.classList.remove('flex');
          activeModal.classList.add('hidden');
        }
        document.body.style.overflow = '';
        activeModal = null;
      }, 300);
    }

    // Navázání eventů
    folderButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-modal-target');
        if (!targetId) return;
        openModal(targetId);
      });
    });

    closeButtons.forEach(btn => {
      btn.addEventListener('click', closeModal);
    });

    backdrops.forEach(backdrop => {
      backdrop.addEventListener('click', closeModal);
    });

    // Zavření pomocí ESCAPE
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && activeModal) {
        closeModal();
      }
    });
  }
</script>

