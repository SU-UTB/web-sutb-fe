import Breadcrumbs from '../components/organisms/Breadcrumbs.astro';

// 1. Změna na '**/*.webp' zajistí, že Astro prohledá i podložky (2024, 2023 atd.)
const images = import.meta.glob('../images/fotky_nahledy/**/*.webp', { eager: true });

const getImage = (fileName: string | any) => {
  if (typeof fileName !== 'string') return fileName;

  // Najdeme cestu, kde se název souboru přesně shoduje s koncem cesty (včetně lomítka)
  const imagePath = Object.keys(images).find((path) => 
    path === `../images/fotky_nahledy/${fileName}` || path.endsWith(`/${fileName}`)
  );

  if (!imagePath) {
    console.warn(`Obrázek ${fileName} nebyl nalezen ve složce fotky_nahledy.`);
    return fileName;
  }

  return images[imagePath].default;
};

// 2. Přidána funkce pro skloňování slova album
const getAlbumWord = (count: number) => {
  if (count === 1) return 'album';
  if (count >= 2 && count <= 4) return 'alba';
  return 'alb';
};

